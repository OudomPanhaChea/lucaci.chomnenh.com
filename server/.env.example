# Copy to .env and fill in

PORT=5001
NODE_ENV=development

# MySQL / MariaDB
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=chamnenh_pos

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# CORS (client origin in dev; in prod same-origin so this is unused)
CLIENT_ORIGIN=http://localhost:3000

# Seed admin account (used by `npm run seed`)
ADMIN_NAME=Owner
ADMIN_EMAIL=admin@chamnenh.com
ADMIN_PASSWORD=admin12345
